{
  "name": "movesia",
  "productName": "Movesia",
  "version": "0.1.1",
  "description": "AI-powered desktop assistant for Unity Editor — manage scenes, GameObjects, and scripts through natural conversation",
  "main": ".vite/build/main.js",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "keywords": [
    "unity",
    "ai",
    "game-development",
    "electron",
    "langraph",
    "desktop-app"
  ],
  "author": {
    "name": "Movesia"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hannyel0/Movesia.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "electron-winstaller",
      "@tailwindcss/oxide",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "zod": "3.25.67"
    }
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write src",
    "clean": "rimraf node_modules .vite pnpm-lock.yaml",
    "postinstall": "husky",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "release": "standard-version",
    "major": "npm run release -- --release-as major",
    "minor": "npm run release -- --release-as minor",
    "patch": "npm run release -- --release-as patch",
    "push-release": "git push --follow-tags origin master"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@langchain/core": "^1.1.28",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.2.10",
    "@langchain/tavily": "^1.2.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "^1.8.1",
    "dotenv": "^17.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-window-state": "^5.0.3",
    "langchain": "^1.2.27",
    "lucide-react": "^0.544.0",
    "marked": "^17.0.3",
    "prettier": "^3.6.2",
    "prettier-plugin-space-before-function-paren": "^0.0.9",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.7.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.6",
    "update-electron-app": "^3.1.2",
    "use-stick-to-bottom": "^1.1.3",
    "ws": "^8.19.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^2.0.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "5.0.4",
    "classnames": "^2.5.1",
    "cross-env": "^10.0.0",
    "electron": "38.2.1",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "9.1.7",
    "lint-staged": "^16.1.2",
    "neostandard": "^0.12.2",
    "pinst": "^3.0.0",
    "rimraf": "^6.0.1",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.11",
    "ts-node": "10.9.2",
    "typescript": "~5.9.0",
    "vite": "^7.0.6",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-svgr": "4.5.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
